# ============================================================
# BAD DECISION — Frontend Environment Variables
# ============================================================
# Copy this to .env.local and fill in your actual values
# ============================================================

# CLERK (Required — Authentication)
# Get keys at: https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key
CLERK_SECRET_KEY=sk_test_your-secret-key

# SUPABASE (Required — Database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# BACKEND API (Required)
NEXT_PUBLIC_BACKEND_URL=https://your-backend.onrender.com
NEXT_PUBLIC_API_SECRET=your-api-secret

# PAYSTACK (Required — Payments)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your-public-key
