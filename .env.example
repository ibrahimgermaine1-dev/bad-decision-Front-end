# ============================================================
# BAD DECISION — Frontend Environment Variables
# ============================================================
# Copy this to .env.local and fill in your actual values.
# These MUST also be set in Vercel (Settings > Environment Variables).
# ============================================================

# ── CLERK (Authentication) ──────────────────────────────────
# Sign up at https://dashboard.clerk.com/ and create an application.
# Copy the keys from API Keys page.
# IMPORTANT: Without real Clerk keys, sign-in/sign-up pages will show a
# "coming soon" message instead of crashing.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-real-publishable-key
CLERK_SECRET_KEY=sk_test_your-real-secret-key

# ── SUPABASE (Database) ─────────────────────────────────────
# Create a project at https://supabase.com/
# Find these in Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only key (for webhooks and admin operations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── BACKEND API ─────────────────────────────────────────────
# The Python backend URL on Render
NEXT_PUBLIC_BACKEND_URL=https://bad-decision-backend-main.onrender.com

# ── PAYSTACK (Payments) ─────────────────────────────────────
# Get your public key at https://dashboard.paystack.com/
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key
