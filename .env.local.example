# ============================================================
# BAD DECISION — Frontend Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# For Vercel production, set these in the Vercel dashboard
# (Settings → Environment Variables → Production).

# ============================================================
# CLERK (Authentication)
# ============================================================
# Get these from https://dashboard.clerk.com
# API Keys → Production (or Development for local testing)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_or_live_here
CLERK_SECRET_KEY=sk_test_or_live_here
# Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_here

# ============================================================
# SUPABASE (Database)
# ============================================================
# Get these from https://supabase.com/dashboard
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ_anon_key_here
# Service role key — NEVER expose to the browser. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=eyJ_service_role_key_here

# ============================================================
# PAYSTACK (Payments — Nigerian Naira + USD)
# ============================================================
# Get these from https://dashboard.paystack.com
# Settings → API Keys & Webhooks
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_or_test_here
PAYSTACK_SECRET_KEY=sk_live_or_test_here
# NOTE: Paystack does NOT use a separate webhook secret.
# Webhook signatures are verified using your PAYSTACK_SECRET_KEY above
# (HMAC-SHA512). You only need to enter your webhook URL in the
# Paystack dashboard (Settings → API Keys & Webhooks → Test/Live Webhook URL):
#   https://bad-decision-front-end.vercel.app/api/webhooks/paystack

# ============================================================
# BACKEND (FastAPI on Render)
# ============================================================
# The URL of your Render backend service
NEXT_PUBLIC_BACKEND_URL=https://bad-decision-backend-main.onrender.com
BACKEND_URL=https://bad-decision-backend-main.onrender.com
# Shared secret between frontend and backend. MUST match the
# BACKEND_API_SECRET value set on Render exactly.
BACKEND_API_SECRET=your_random_32_char_secret_here

# ============================================================
# SENTRY (Error Tracking) — OPTIONAL but recommended
# ============================================================
# Get these from https://sentry.io → Settings → Projects →
# [your-frontend-project] → Client Keys (DSN)
#
# The public DSN is safe to expose in the browser. It can only send
# events TO Sentry, not read them. The private DSN (SENTRY_DSN, no
# NEXT_PUBLIC_ prefix) is used server-side for API route errors.
#
# If you leave these blank, Sentry is silently skipped — no errors.
NEXT_PUBLIC_SENTRY_DSN=https://example@sentry.io/1234567
SENTRY_DSN=https://example@sentry.io/1234567
SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# For source-map uploads during Vercel build (optional):
# SENTRY_AUTH_TOKEN=sntrys_eyJpYX...
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=bad-decision-frontend
